FROM gcc:13 AS builder

WORKDIR /build

COPY backend/main.cpp backend/Matchingengine.cpp backend/Matchingengine.h backend/Order.h backend/Orderbook.h backend/Trade.h ./

RUN g++ -std=c++17 -O2 main.cpp Matchingengine.cpp -o exchange


FROM python:3.11-slim AS runtime

WORKDIR /app

COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY --from=builder /build/exchange ./exchange
RUN chmod +x ./exchange

COPY backend/server.py .

ENV ENGINE_BINARY=./exchange
ENV ENGINE_CWD=.

EXPOSE 8000

CMD ["uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8000"]